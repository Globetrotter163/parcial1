<?xml version="1.0"?>
<robot name="brazo_custom">

  <!-- BASE -->
  <link name="base_link"/>

  <joint name="joint_1" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="3"/>
  </joint>

  <!-- LINK 1 -->
  <link name="link_1">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="2.0"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 0.8 1"/>
      </material>
    </visual>
  </link>

  <joint name="joint_2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="2.0 0 0" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="3"/>
  </joint>

  <!-- LINK 2 -->
  <link name="link_2">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.0"/>
      </geometry>
      <material name="green">
        <color rgba="0 0.8 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="joint_3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="1.0 0 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.1416" upper="3.1416" effort="10" velocity="3"/>
  </joint>

  <!-- LINK 3 -->
  <link name="link_3">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="1.0"/>
      </geometry>
      <material name="red">
        <color rgba="0.8 0 0 1"/>
      </material>
    </visual>
  </link>

  <!-- EE -->
  <joint name="joint_ee" type="fixed">
    <parent link="link_3"/>
    <child link="end_effector"/>
    <origin xyz="0 0 1.0"/>
  </joint>

  <link name="end_effector">
    <visual>
      <geometry>
        <sphere radius="0.08"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>

</robot>